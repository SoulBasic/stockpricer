# Copy to .env and adjust as needed: `cp .env.example .env`
# docker compose reads .env automatically; these also work for bare
# `python3 stock_server.py` runs.

# --- network ---
HOST=0.0.0.0              # bind address inside the process
PORT=8849                 # listen port
# docker compose only: host interface to publish on. Default loopback ->
# reach it via a reverse proxy. Set 0.0.0.0 to expose directly (not advised).
BIND_ADDR=127.0.0.1

# --- timeouts / performance (seconds) ---
HTTP_TIMEOUT=12           # per-source upstream fetch timeout
QUOTE_TIMEOUT=8           # overall budget to race a quote across sources

# --- caching ---
RESOLVE_CACHE_TTL=600     # fuzzy-search / resolve cache TTL
RESOLVE_CACHE_MAX=1024    # max cached resolutions (LRU eviction bounds memory)

# --- hardening (matter when the port is reachable from untrusted networks) ---
SOCKET_TIMEOUT=20         # client socket read timeout (anti-slowloris)
MAX_RESPONSE_BYTES=5000000  # cap per upstream response (anti-OOM / gzip bomb)
RATE_LIMIT_RPM=120        # per-client requests/min for /quote & /search (0 disables)
TRUST_PROXY=0             # 1 = trust X-Real-IP / X-Forwarded-For (set only behind a known proxy)

# --- auth ---
# When set, every request except /health must send `Authorization: Bearer <token>`.
# Comma-separate multiple tokens to allow rotation. Empty = auth disabled.
# AUTH_TOKEN=change-me-to-a-long-random-secret
