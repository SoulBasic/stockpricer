# Copy to .env and adjust as needed: `cp .env.example .env`
# docker compose reads .env automatically; these also work for bare
# `python3 stock_server.py` runs.

# --- network ---
HOST=0.0.0.0          # bind address
PORT=8849             # listen port

# --- timeouts / performance (seconds) ---
HTTP_TIMEOUT=12       # per-source upstream fetch timeout
QUOTE_TIMEOUT=8       # overall budget to race a quote across sources
US_PREFER_GRACE=2.5   # extra wait for the richer US source (pre/post/overnight)

# --- caching ---
RESOLVE_CACHE_TTL=600 # fuzzy-search / resolve cache TTL
